{
  "name": "mosvera-providers",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Reference Mosvera provider adapters and shared provider tests.",
  "license": "Apache-2.0",
  "workspaces": [
    "_base",
    "openai",
    "flux",
    "sdxl",
    "heygen",
    "google",
    "runway",
    "elevenlabs",
    "firefly",
    "meshy"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "ci": "npm run build && npm run typecheck && npm run test:workspaces && npm run test:providers",
    "smoke:live": "node scripts/smoke-live.mjs",
    "test": "npm run test:workspaces && npm run test:providers",
    "test:providers": "vitest run test",
    "test:workspaces": "npm run test --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
