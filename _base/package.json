{
  "name": "@mosvera/provider-base",
  "version": "0.1.0",
  "description": "Shared provider adapter contract and deterministic emission engine for Mosvera.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://mosvera.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosvera/providers.git",
    "directory": "_base"
  },
  "bugs": {
    "url": "https://github.com/mosvera/providers/issues"
  },
  "keywords": [
    "mosvera",
    "provider-adapter",
    "aesthetic-infrastructure",
    "ai"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run typecheck && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mosvera/runtime": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.7",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.2"
  }
}
