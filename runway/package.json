{
  "name": "@mosvera/provider-runway",
  "version": "0.1.2",
  "description": "Translate resolved Mosvera aesthetics into Runway image and video payloads.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://mosvera.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosvera/providers.git",
    "directory": "runway"
  },
  "bugs": {
    "url": "https://github.com/mosvera/providers/issues"
  },
  "keywords": [
    "mosvera",
    "runway",
    "gen-4",
    "video-generation",
    "provider-adapter"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run typecheck && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "execute:manual": "tsx test/execute.manual.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mosvera/runtime": "^0.1.2",
    "@mosvera/provider-base": "^0.1.3",
    "@runwayml/sdk": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
